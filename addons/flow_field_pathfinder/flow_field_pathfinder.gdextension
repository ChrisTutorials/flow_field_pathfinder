[configuration]
entry_symbol = "flow_field_pathfinder_library_init"
compatibility_minimum = "4.2"
reloadable = true

[libraries]
linux.debug.x86_64 = "res://addons/flow_field_pathfinder/bin/libflow_field_pathfinder.linux.template_debug.x86_64.so"
linux.release.x86_64 = "res://addons/flow_field_pathfinder/bin/libflow_field_pathfinder.linux.template_release.x86_64.so"
web.debug.threads.wasm32 = "res://addons/flow_field_pathfinder/bin/libflow_field_pathfinder.web.template_debug.wasm32.wasm"
web.release.threads.wasm32 = "res://addons/flow_field_pathfinder/bin/libflow_field_pathfinder.web.template_release.wasm32.wasm"
